# ==========================================
# MELANT IA - Variables de Entorno
# ==========================================
# Copia este archivo como .env y completa con tus credenciales

# ---------- MongoDB Atlas ----------
# Obtén tu connection string en: https://cloud.mongodb.com
# Ejemplo: mongodb+srv://<usuario>:<password>@cluster0.xxxxx.mongodb.net/
MONGODB_URI=mongodb+srv://tu_usuario:tu_password@cluster0.xxxxx.mongodb.net/
DB_NAME=melant_ia

# ---------- Cloudinary ----------
# Regístrate en: https://cloudinary.com/users/register/free
# Encuentra tus credenciales en el Dashboard
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_ap
i_key
CLOUDINARY_API_SECRET=tu_api_secret

# ---------- JWT (Autenticación) ----------
# Genera una clave segura: python -c "import secrets; print(secrets.urlsafe_alphabet(32))"
SECRET_KEY=tu_secret_key_muy_segura_y_larga_cambia_esto
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ---------- CORS ----------
# URL de tu frontend (cambia en producción)
FRONTEND_URL=http://localhost:5173

# ---------- Servidor ----------
HOST=0.0.0.0
PORT=8000
DEBUG=False